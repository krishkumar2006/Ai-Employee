# =============================================================================
# .env.cloud — Oracle Always Free VM (COMMITTED TO GIT — no secrets here)
# =============================================================================
# DEPLOYMENT MODE: cloud
#   Allowed  : email_read, email_triage, email_draft, plan_generate,
#              social_draft, odoo_read, ceo_briefing, ralph_loop, health_check
#   BLOCKED  : email_send, odoo_confirm, odoo_write, whatsapp_*, social_post_*,
#              approval_execute, payment_process, banking_*, credential_access
#
# SECRETS RULE: This file is tracked in Git.
#   ALL values here must be non-sensitive (URLs, usernames, intervals, flags).
#   Real secrets live in vault/Secrets/.env.cloud.secrets (gitignored, never synced).
#   Set ANTHROPIC_API_KEY and sensitive keys in the VM environment:
#     export ANTHROPIC_API_KEY=sk-ant-...   (added to ~/.bashrc or systemd unit)
# =============================================================================

DEPLOYMENT_MODE=cloud

# =============================================================================
# Safety flags
# =============================================================================

# DRY_RUN: set to "true" to test without executing any destructive actions.
# Useful for verifying vault sync, draft generation, and watcher logic.
DRY_RUN=false

# =============================================================================
# Rate limiting (actions per hour per category)
# Keeps the cloud agent from spamming Claude or filling drafts too fast.
# =============================================================================
RATE_LIMIT_ODOO_WRITE=0        # 0 = never allowed on cloud
RATE_LIMIT_EMAIL_SEND=0        # 0 = never allowed on cloud
RATE_LIMIT_SOCIAL_POST=0       # 0 = never allowed on cloud (posts are LOCAL)
RATE_LIMIT_SOCIAL_DRAFT=20     # max Claude draft calls per hour
RATE_LIMIT_CLAUDE_CALL=50      # max total Claude CLI calls per hour
RATE_LIMIT_APPROVAL=0          # 0 = cloud cannot execute approvals
RATE_LIMIT_DEFAULT=10          # fallback for any unlisted action

# =============================================================================
# Anthropic / Claude CLI
# API key must be set in the VM environment — NOT here (committed file)
# =============================================================================
# ANTHROPIC_API_KEY  ← set via: export ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_TIMEOUT=180              # seconds; social drafts may be slow

# =============================================================================
# Gmail — READ only on cloud
# gmail_watcher.py polls inbox and creates vault/Needs_Action/email/ cards.
# SMTP sending (GMAIL_APP_PASSWORD) intentionally omitted — cloud cannot send.
# =============================================================================
GMAIL_ADDRESS=your@gmail.com
GMAIL_POLL_INTERVAL=60          # seconds between inbox polls
# GMAIL_APP_PASSWORD  ← OMITTED — cloud blocked from sending email

# =============================================================================
# Odoo — READ only on cloud
# ceo_briefing.py reads invoices/partners for report generation.
# ODOO_PASSWORD omitted → confirm/write tools will fail fast if accidentally called.
# =============================================================================
ODOO_URL=https://your-domain.com
ODOO_DB=odoo
ODOO_USER=admin@your-domain.com
# ODOO_PASSWORD  ← OMITTED — cloud cannot confirm invoices or write records

# =============================================================================
# Telegram — alert bot (low-risk: outbound notification only)
# Set token+chat in the VM environment, not here.
# =============================================================================
# TELEGRAM_BOT_TOKEN  ← set via: export TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID    ← set via: export TELEGRAM_CHAT_ID=...

# =============================================================================
# WhatsApp — BLOCKED on cloud (requires local phone session)
# Watcher will not start when DEPLOYMENT_MODE=cloud.
# =============================================================================
# WHATSAPP_*  ← all omitted; orchestrator skips whatsapp_watcher on cloud

# =============================================================================
# Social media — DRAFT only on cloud (posting is LOCAL via Playwright)
# =============================================================================
SOCIAL_DRAFT_PLATFORMS=twitter,meta,linkedin
SOCIAL_DRAFT_POLL=120           # seconds between task polls
SOCIAL_DRAFT_DEFAULT_TONE=professional

# Twitter/X — username only (for analytics summary); no password on cloud
X_USERNAME=@YourHandle
# X_PASSWORD  ← OMITTED — cloud cannot post to Twitter

# Meta / LinkedIn — all omitted; posters run LOCAL only
# META_EMAIL / META_PASSWORD / LINKEDIN_EMAIL / LINKEDIN_PASSWORD  ← OMITTED

# =============================================================================
# Approval / HITL — cloud WRITES drafts, LOCAL approves and executes
# =============================================================================
AUTO_APPROVE_BELOW=none         # cloud never auto-approves anything

# =============================================================================
# Vault sync
# =============================================================================
VAULT_SYNC_BRANCH=main
VAULT_SYNC_REMOTE=origin

# =============================================================================
# Timezone
# =============================================================================
TZ=Asia/Karachi
