# =============================================================
# AI Employee — Environment Variables
# =============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — only .env.example is safe to share.
# =============================================================

# --- Gmail (used by gmail_watcher.py + email_mcp.js) ---
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- WhatsApp ---
WHATSAPP_POLL_INTERVAL=30

# --- Gmail Watcher ---
GMAIL_POLL_INTERVAL=60

# --- Claude ---
CLAUDE_TIMEOUT=120

# --- Approval Workflow ---
# Actions matching these types require human approval before execution.
# Comma-separated list of action types.
SENSITIVE_ACTIONS=send_email,delete_file,move_to_archive,reply_whatsapp,forward_email

# Auto-approve threshold: priority levels BELOW this skip approval.
# Options: none (approve everything), low, normal, high
AUTO_APPROVE_BELOW=low

# --- LinkedIn Poster ---
LINKEDIN_POLL_INTERVAL=60

# --- Meta (Facebook + Instagram) — Free (Playwright, no API keys) ---
# No developer account required.
# First run: two browser windows open — log in to facebook.com AND instagram.com
# Sessions saved to vault/.meta_session/facebook/ and /instagram/
#
# META_FB_PAGE_NAME: Your Facebook Page URL slug (e.g. "MyBusiness" for fb.com/MyBusiness)
# Leave blank to post to personal profile instead of a Page.
META_FB_PAGE_NAME=

# --- X (Twitter) — Free (Playwright, no API keys needed) ---
# No developer account required.
# Uses a real browser (Chromium) with persistent session — same approach as WhatsApp.
# First run: browser opens, log in manually at x.com
# Subsequent runs: session auto-restored from vault/.twitter_session/
# No env vars needed for Twitter — just run twitter_poster.py and log in.

# --- Odoo — Gold Tier ---
# ODOO_URL: Base URL of your Odoo instance (local or SaaS)
# ODOO_DB:  Database name — visit http://your-odoo/web/database/selector
# ODOO_USER: Admin login email
# ODOO_PASSWORD: API Key (preferred) or password
#   To generate API Key: Settings → User Profile → Account Security → New API Key
ODOO_URL=http://localhost:8069
ODOO_DB=ai-employee
ODOO_USER=admin@yourcompany.com
ODOO_PASSWORD=your_api_key_or_password_here
