# =============================================================================
# docker/.env.docker — Oracle VM Docker secrets
# =============================================================================
# Copy this file to docker/.env.docker and fill in real values.
# .env.docker is GITIGNORED — never commit real passwords.
#
#   cp docker/.env.docker.example docker/.env.docker
#   nano docker/.env.docker
# =============================================================================

# PostgreSQL password (used by both postgres and odoo containers)
POSTGRES_PASSWORD=change-this-strong-password-min-20-chars

# Odoo master password (shown on /web/database/manager)
ODOO_MASTER_PASSWORD=change-this-admin-password-min-20-chars

# Your domain name (must already point to this VM's public IP)
# Free options: DuckDNS (duckdns.org), nip.io (e.g. 1.2.3.4.nip.io)
DOMAIN=odoo.yourdomain.com

# Email for Let's Encrypt expiry notifications (free)
CERTBOT_EMAIL=your@email.com

# Odoo admin user email (for AI Employee MCP connection)
ODOO_USER=admin@yourdomain.com

# Odoo admin password (same as master password or a separate app password)
ODOO_ADMIN_PASSWORD=change-this-admin-password-min-20-chars
